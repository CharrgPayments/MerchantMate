modules = ["nodejs-20", "postgresql-16"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e-unified-queue"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development npx tsx server/index.ts"
waitForPort = 5000

[[workflows.workflow]]
name = "e2e-unified-queue"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/ci-e2e-unified-queue.sh"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
