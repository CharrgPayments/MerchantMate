# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon or any Postgres instance)
DATABASE_URL=

# Secret used to sign session cookies — any long random string works locally
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Environment ─────────────────────────────────────────────────────────────

# Set to "development" for local dev (enables Vite dev server, auth bypass, etc.)
NODE_ENV=development

# ─── Optional: multi-environment databases ───────────────────────────────────

# Separate DB for development (falls back to DATABASE_URL if not set)
DEV_DATABASE_URL=

# Separate DB for automated tests (falls back to DATABASE_URL if not set)
TEST_DATABASE_URL=

# ─── Optional: email sending (SendGrid) ──────────────────────────────────────
# Leave blank to disable email — the app runs fine without it

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_VERIFIED_SENDER=

# ─── Optional: Google API (maps / places) ────────────────────────────────────

GOOGLE_API_KEY=

# ─── Optional: app URL overrides ─────────────────────────────────────────────

APP_URL=
BASE_URL=
APP_VERSION=

# ─── Replit-only (do not set for local development) ──────────────────────────
# These are injected automatically when running on Replit.
# Setting them locally has no effect and may cause unexpected behaviour.

# REPLIT_DOMAINS=
# REPL_ID=
# ISSUER_URL=
